SEMANTIC_SCHOLAR_API_KEY=
KNOWCRAN_DATA_DIR=data
KNOWCRAN_VAULT_DIR=vault
KNOWCRAN_RATE_LIMIT_SECONDS=1.1

# LLM Provider Configuration
# Set to "none" for deterministic-only mode (default), or "claw" to use Claw Code
MNEMOSYNE_LLM_PROVIDER=none
# Path to Claw binary (auto-detected if sibling ../claw-code-main exists)
# MNEMOSYNE_CLAW_BIN=../claw-code-main/rust/target/debug/claw
# Model to use with Claw (default: sonnet)
# MNEMOSYNE_CLAW_MODEL=sonnet
# Claw permission mode (default: read-only)
# MNEMOSYNE_CLAW_PERMISSION_MODE=read-only
# Timeout for Claw subprocess calls in seconds (default: 600)
# MNEMOSYNE_CLAW_TIMEOUT_SECONDS=600
# Max retries for Claw calls (default: 2)
# MNEMOSYNE_CLAW_MAX_RETRIES=2
# Directory for LLM output cache (default: data/raw/llm)
# MNEMOSYNE_LLM_CACHE_DIR=data/raw/llm

# PDF Download Configuration
# Enable PDF downloading (default: true)
# MNEMOSYNE_PDF_DOWNLOAD_ENABLED=true
# Directory for storing downloaded PDFs (default: data/pdfs)
# MNEMOSYNE_PDF_DIR=data/pdfs
# Download strategy: fastest, oa_first, legal_only, scihub_only (default: fastest)
# MNEMOSYNE_PDF_STRATEGY=fastest
# Enable Sci-Hub as a source (default: true)
# WARNING: Sci-Hub may not comply with publisher terms of service.
# For institutional use, set MNEMOSYNE_PDF_STRATEGY=legal_only instead.
# MNEMOSYNE_SCIHUB_ENABLED=true
# Enable LibGen as a source (default: true)
# WARNING: LibGen may not comply with publisher terms of service.
# For institutional use, set MNEMOSYNE_PDF_STRATEGY=legal_only instead.
# MNEMOSYNE_LIBGEN_ENABLED=true
# Enable Tor for anonymous downloads (default: false)
# MNEMOSYNE_TOR_ENABLED=false
# Number of parallel batch download workers (default: 5)
# MNEMOSYNE_PDF_BATCH_WORKERS=5

# Recommended settings for institutional/compliance-sensitive environments:
# MNEMOSYNE_PDF_STRATEGY=legal_only
# MNEMOSYNE_SCIHUB_ENABLED=false
# MNEMOSYNE_LIBGEN_ENABLED=false
