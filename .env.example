SEMANTIC_SCHOLAR_API_KEY=
KNOWCRAN_DATA_DIR=data
KNOWCRAN_VAULT_DIR=vault
KNOWCRAN_RATE_LIMIT_SECONDS=1.1

# LLM Provider Configuration
# Set to "none" for deterministic-only mode (default), or "claw" to use Claw Code
MNEMOSYNE_LLM_PROVIDER=none
# Path to Claw binary (auto-detected if sibling ../claw-code-main exists)
# MNEMOSYNE_CLAW_BIN=../claw-code-main/rust/target/debug/claw
# Model to use with Claw (default: sonnet)
# MNEMOSYNE_CLAW_MODEL=sonnet
# Claw permission mode (default: read-only)
# MNEMOSYNE_CLAW_PERMISSION_MODE=read-only
# Timeout for Claw subprocess calls in seconds (default: 600)
# MNEMOSYNE_CLAW_TIMEOUT_SECONDS=600
# Max retries for Claw calls (default: 2)
# MNEMOSYNE_CLAW_MAX_RETRIES=2
# Directory for LLM output cache (default: data/raw/llm)
# MNEMOSYNE_LLM_CACHE_DIR=data/raw/llm

# PDF Downloading & Core Parsing (Sci-Hub/LibGen enabled by default for convenience)
# To disable unauthorized sources completely, set false.
MNEMOSYNE_PDF_DOWNLOAD_ENABLED=true
MNEMOSYNE_PDF_DIR=data/pdfs
MNEMOSYNE_PDF_STRATEGY=fastest
MNEMOSYNE_SCIHUB_ENABLED=true
MNEMOSYNE_LIBGEN_ENABLED=true
MNEMOSYNE_PDF_PARSER=auto
MINERU_API_URL=http://127.0.0.1:8000

# OpenAI Embedding Configuration for Hybrid Search
# Set MNEMOSYNE_EMBEDDING_PROVIDER=none to degrade to FTS5 keyword-only search.
# Set MNEMOSYNE_EMBEDDING_PROVIDER=local to use the local embedding server.
MNEMOSYNE_EMBEDDING_PROVIDER=openai
MNEMOSYNE_EMBEDDING_MODEL=text-embedding-3-large
# MNEMOSYNE_EMBEDDING_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=

# Local Services Managed Layer Settings
# MinerU modes: managed (starts MinerU automatically), external (uses MINERU_API_URL), off (disables MinerU)
MNEMOSYNE_MINERU_MODE=managed
# MinerU backends: docker (preferred on WSL2/Linux), subprocess (uses mineru-api executable)
MNEMOSYNE_MINERU_BACKEND=docker
# GPU acceleration for MinerU (requires NVIDIA runtime config)
MNEMOSYNE_MINERU_GPU=false
# Number of MinerU worker processes (default: 1)
MNEMOSYNE_MINERU_WORKERS=1
# Model directory source (set to local if downloading models offline)
# MINERU_MODEL_SOURCE=local
# Local host path to store MinerU models (mounted inside docker)
# MNEMOSYNE_MINERU_MODELS_DIR=data/models/mineru
# Local host path to store magic-pdf.json (mounted inside docker)
# MNEMOSYNE_MINERU_CONFIG_FILE=data/mineru/magic-pdf.json

# Local Embedding Mode Settings (when MNEMOSYNE_EMBEDDING_PROVIDER=local)
# Local embedding modes: managed (starts embedding-server automatically), external (uses existing endpoint)
MNEMOSYNE_LOCAL_EMBEDDING_MODE=managed
MNEMOSYNE_LOCAL_EMBEDDING_URL=http://127.0.0.1:8010/v1
MNEMOSYNE_LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
# Device for local embeddings: cpu (default) or cuda
MNEMOSYNE_LOCAL_EMBEDDING_DEVICE=cpu
# Batch size for local embedding requests (default: 16)
MNEMOSYNE_LOCAL_EMBEDDING_BATCH_SIZE=16

